# ClassCadence — environment variables
# Copy this file to .env.local and fill in the values you saved during signup
# (see ClassCadence_Launch_Plan.md, Section 2 for where each value comes from).

# ---- Supabase ---------------------------------------------------------------
# Project Settings → API → URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace-me...
# Project Settings → API → service_role (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace-me...
# Project Settings → Database → Connection string (URI)
# Used by the Supabase CLI for migrations.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ---- Resend (email) ---------------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_...replace-me...
# Until you add a custom domain, use the shared sender below.
# Once your domain is verified in Resend, change this to e.g. hello@classcadence.com
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=ClassCadence

# ---- Inngest (background jobs) ---------------------------------------------
# https://app.inngest.com → Settings → Event Keys
INNGEST_EVENT_KEY=replace-me
INNGEST_SIGNING_KEY=signkey-...replace-me...

# ---- App --------------------------------------------------------------------
# In production set this to your Vercel URL (e.g. https://classcadence-abc.vercel.app)
# or your custom domain once you buy one.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- WhatsApp (DEFER — fill in only when first real tenant signs up) -------
# See ClassCadence_Launch_Plan.md Section 6.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ---- Sentry (optional, add when first incident occurs) ---------------------
SENTRY_DSN=
